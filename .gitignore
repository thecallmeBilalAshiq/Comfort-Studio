# Dependency folders
frontend/node_modules
backend/node_modules

# Next.js build cache
frontend/.next
backend/.next
frontend/tsconfig.tsbuildinfo

# Environment variables & secrets
backend/.env
frontend/.env.local
backend/firebase-service-account.json
frontend/firebase-service-account.json

# SQLite database files
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Uploaded images & static files
backend/uploads/*
!backend/uploads/.gitkeep

# Log files
backend/server.log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
.vercel
.env*
